# GhostClip — Ghost Layer's internal social content agent. This file documents the env surface CLIP needs to operate.
# CLIP reads these at startup. Values live in the operator's local .env, not this repo.

# -- Ghost Gate (Layer-0) --------------------------------------------
# Used by CLIP to authenticate when calling NULL agents.
# Fixed — CLIP talks to one Ghost Gate deployment, not pluggable.
GHOST_GATE_BASE_URL=https://api.ghostlayersecurity.com
# Fixed — CLIP's identity on Ghost Gate.
GHOST_GATE_AGENT_ID=clip
GHOST_GATE_PRIVATE_KEY=

# -- Pixa (image-to-video, BG removal, upscaling) --------------------
PIXA_API_KEY=

# -- ElevenLabs (voiceover generation) -------------------------------
ELEVENLABS_API_KEY=

# -- Publora (multi-platform publish) --------------------------------
PUBLORA_API_KEY=

# -- Xpoz (trend research) -------------------------------------------
XPOZ_API_KEY=

# -- Ghost Layer /api/scan (pre-publish content check) ---------------
# CLIP sends final caption + script through Ghost Layer before publishing
# so anything off-brand or sensitive is flagged.
GHOST_LAYER_API_KEY=
