# GhostClip — environment variables
# Copy to .env and fill in real values. Never commit .env.

# -- Ghost Gate (Layer-0) --------------------------------------------
# Used by CLIP to authenticate when calling NULL agents.
GHOST_GATE_BASE_URL=https://api.ghostlayersecurity.com
GHOST_GATE_AGENT_ID=clip
GHOST_GATE_PRIVATE_KEY=

# -- Pixa MCP (image-to-video, BG removal, upscaling) ----------------
PIXA_API_KEY=

# -- ElevenLabs (voiceover generation) -------------------------------
ELEVENLABS_API_KEY=

# -- Ayrshare (multi-platform publish) -------------------------------
AYRSHARE_API_KEY=

# -- Xpoz (trend research) -------------------------------------------
XPOZ_API_KEY=

# -- Ghost Layer /api/scan (pre-publish content check) ---------------
# CLIP sends final caption + script through Ghost before publishing
# so anything off-brand or sensitive is flagged.
GHOST_LAYER_API_KEY=
